import { Button, ComboBox, ProgressIndicator, VerticalBox, HorizontalBox } from "std-widgets.slint";

export global InstallerLogic {
    callback start_install(string);
    callback launch_terminal();
    callback update_system();
    
    in property <float> progress: 0.0;
    in property <string> status_text: "Ready to deploy.";
}

export component InstallerWindow inherits Window {
    title: "Kestrel OS Welcome";
    width: 600px;
    height: 400px;
    background: #1e1e2e;
    default-font-family: "sans-serif";

    in-out property <int> active_step: 0;
    property <string> selected_disk: "/dev/nvme0n1";

    VerticalBox {
        padding: 30px;
        spacing: 15px;

        // Header - Professional sizing
        Text {
            text: "Kestrel OS";
            font-size: 20px;
            font-weight: 500;
            color: #cba6f7;
            horizontal-alignment: center;
        }

        // Visual Separator
        Rectangle { height: 1px; background: #313244; }

        // STEP 0: Dashboard (The Welcome App)
        if (root.active_step == 0) : VerticalBox {
            alignment: center;
            spacing: 15px;
            
            Text {
                text: "Welcome to Kestrel Arch";
                font-size: 16px;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            
            Text {
                text: "Select an option below to manage the live environment or install the system.";
                font-size: 12px;
                color: #bac2de;
                horizontal-alignment: center;
            }

            HorizontalBox {
                padding-top: 20px;
                alignment: center;
                spacing: 15px;
                
                Button {
                    text: "Launch Terminal";
                    clicked => { InstallerLogic.launch_terminal(); }
                }
                Button {
                    text: "Update System";
                    clicked => { InstallerLogic.update_system(); }
                }
                Button {
                    text: "Install Kestrel";
                    primary: true;
                    clicked => { root.active_step = 1; }
                }
            }
        }

        // STEP 1: Target Choice Screen
        if (root.active_step == 1) : VerticalBox {
            alignment: center;
            spacing: 12px;
            Text {
                text: "Select Target Drive";
                font-size: 14px;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            ComboBox {
                model: ["/dev/nvme0n1", "/dev/sda"];
                current-value: root.selected_disk;
                selected(val) => { root.selected_disk = val; }
            }
            Text {
                text: "Warning: All data on this drive will be erased.";
                color: #f38ba8;
                font-size: 12px;
                horizontal-alignment: center;
            }
            HorizontalBox {
                padding-top: 20px;
                alignment: center;
                spacing: 10px;
                Button {
                    text: "Back to Menu";
                    clicked => { root.active_step = 0; }
                }
                Button {
                    text: "Start Installation";
                    primary: true;
                    clicked => { 
                        root.active_step = 2; 
                        InstallerLogic.start_install(root.selected_disk);
                    }
                }
            }
        }

        // STEP 2: Live Progress Output Screen
        if (root.active_step == 2) : VerticalBox {
            alignment: center;
            spacing: 12px;
            Text {
                text: "Deploying system files...";
                font-size: 14px;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            ProgressIndicator {
                progress: InstallerLogic.progress;
            }
            Text {
                text: InstallerLogic.status_text;
                color: #a6adc8;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }

        // STEP 3: Complete Screen
        if (root.active_step == 3) : VerticalBox {
            alignment: center;
            spacing: 12px;
            Text {
                text: "Installation Complete";
                font-size: 18px;
                color: #a6e3a1;
                horizontal-alignment: center;
            }
            Text {
                text: "Your system is ready to use.";
                color: #bac2de;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }
}
