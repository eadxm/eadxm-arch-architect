import { Button, ComboBox, ProgressIndicator, VerticalBox, HorizontalBox, LineEdit, CheckBox } from "std-widgets.slint";

export global InstallerLogic {
    // Now accepts all 11 variables required by main.rs
    callback start_install(string, string, string, string, string, string, string, string, string, string, string);
    callback launch_terminal();
    callback update_system();
    
    in property <float> progress: 0.0;
    in property <string> status_text: "Ready to deploy.";
}

export component InstallerWindow inherits Window {
    title: "Kestrel OS Installer";
    width: 700px;  // Slightly wider for text inputs
    height: 600px; // Slightly taller for the wizard flow
    background: #1e1e2e;
    default-font-family: "Noto Sans, Roboto, sans-serif";

    in-out property <int> active_step: 0;
    
    in property <[string]> available_disks: ["Scanning hardware..."];
    
    // --- STATE MANAGEMENT ---
    
    // Step 1: Storage
    property <string> selected_disk: root.available_disks[0];
    property <string> selected_mode: "2. Offline (Fast, Local Cache)";
    property <string> selected_part: "3. HARD NUKE - Wipe the entire drive";
    
    // Step 2: Accounts
    property <string> in_hostname: "kestrel";
    property <string> in_username: "kestrel_user";
    property <string> in_password: "";
    property <string> in_root_password: "";
    
    // Step 3: Software
    property <string> selected_browser: "1. Zen Browser (Recommended)";
    property <bool> perf_enabled: true;
    property <string> selected_de: "1. Hyprland";
    property <string> selected_boot: "4. Limine";

    VerticalBox {
        padding: 40px;
        spacing: 20px;

        // --- GLOBAL HEADER ---
        Text {
            text: "Kestrel OS";
            font-size: 28px;
            font-weight: 700;
            color: #cba6f7;
            horizontal-alignment: center;
        }

        Rectangle { height: 1px; background: #313244; }

        // ==========================================
        // STEP 0: Dashboard
        // ==========================================
        if (root.active_step == 0) : VerticalBox {
            alignment: center;
            spacing: 20px;
            
            Text {
                text: "Welcome to Kestrel Arch";
                font-size: 18px;
                font-weight: 600;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            
            Text {
                text: "Select an option below to manage the live environment or deploy the system.";
                font-size: 13px;
                color: #bac2de;
                horizontal-alignment: center;
            }

            HorizontalBox {
                padding-top: 25px;
                alignment: center;
                spacing: 20px;
                
                Button {
                    text: "Launch Terminal";
                    height: 40px;
                    clicked => { InstallerLogic.launch_terminal(); }
                }
                Button {
                    text: "Update System";
                    height: 40px;
                    clicked => { InstallerLogic.update_system(); }
                }
                Button {
                    text: "Deploy Kestrel";
                    primary: true;
                    height: 40px;
                    clicked => { root.active_step = 1; }
                }
            }
        }

        // ==========================================
        // STEP 1: Storage & Strategy
        // ==========================================
        if (root.active_step == 1) : VerticalBox {
            alignment: center;
            spacing: 15px;
            padding-left: 40px;
            padding-right: 40px;
            
            VerticalBox {
                spacing: 5px;
                Text { text: "Target Drive:"; font-size: 13px; font-weight: 600; color: #bac2de; }
                ComboBox {
                    model: root.available_disks;
                    current-value: root.selected_disk;
                    selected(val) => { root.selected_disk = val; }
                    height: 35px;
                }
            }

            VerticalBox {
                spacing: 5px;
                Text { text: "Installation Mode:"; font-size: 13px; font-weight: 600; color: #bac2de; padding-top: 5px; }
                ComboBox {
                    model: ["1. Online (Download Latest)", "2. Offline (Fast, Local Cache)"];
                    current-value: root.selected_mode;
                    selected(val) => { root.selected_mode = val; }
                    height: 35px;
                }
            }
            
            VerticalBox {
                spacing: 5px;
                Text { text: "Partitioning Strategy:"; font-size: 13px; font-weight: 600; color: #bac2de; padding-top: 5px; }
                ComboBox {
                    model: ["1. SAFE MULTI-BOOT (Alongside OS)", "2. REPLACE LINUX (Wipe Linux Partitions)", "3. HARD NUKE (Wipe Entire Drive)", "4. WINDOWS RESIZE (Shrink C: Drive)", "5. TARGET NUKE (Wipe C: Drive Only)"];
                    current-value: root.selected_part;
                    selected(val) => { root.selected_part = val; }
                    height: 35px;
                }
            }
            
            HorizontalBox {
                padding-top: 20px;
                alignment: center;
                spacing: 15px;
                Button { text: "Back"; height: 40px; clicked => { root.active_step = 0; } }
                Button { text: "Next: Accounts"; primary: true; height: 40px; clicked => { root.active_step = 2; } }
            }
        }

        // ==========================================
        // STEP 2: Account Creation
        // ==========================================
        if (root.active_step == 2) : VerticalBox {
            alignment: center;
            spacing: 15px;
            padding-left: 60px;
            padding-right: 60px;

            VerticalBox {
                spacing: 5px;
                Text { text: "System Hostname:"; font-size: 13px; color: #bac2de; }
                LineEdit { text: root.in_hostname; edited(val) => { root.in_hostname = val; } height: 35px; }
            }

            VerticalBox {
                spacing: 5px;
                Text { text: "Username:"; font-size: 13px; color: #bac2de; }
                LineEdit { text: root.in_username; edited(val) => { root.in_username = val; } height: 35px; }
            }

            VerticalBox {
                spacing: 5px;
                Text { text: "User Password:"; font-size: 13px; color: #bac2de; }
                LineEdit { input-type: password; text: root.in_password; edited(val) => { root.in_password = val; } height: 35px; }
            }

            VerticalBox {
                spacing: 5px;
                Text { text: "Root Password (leave blank to match User):"; font-size: 13px; color: #bac2de; }
                LineEdit { input-type: password; text: root.in_root_password; edited(val) => { root.in_root_password = val; } height: 35px; }
            }

            HorizontalBox {
                padding-top: 20px;
                alignment: center;
                spacing: 15px;
                Button { text: "Back"; height: 40px; clicked => { root.active_step = 1; } }
                Button { 
                    text: "Next: Software"; 
                    primary: true; 
                    height: 40px; 
                    enabled: root.in_username != "" && root.in_password != ""; // Prevent empty passwords
                    clicked => { root.active_step = 3; } 
                }
            }
        }

        // ==========================================
        // STEP 3: Software & Deployment
        // ==========================================
        if (root.active_step == 3) : VerticalBox {
            alignment: center;
            spacing: 15px;
            padding-left: 40px;
            padding-right: 40px;
            
            VerticalBox {
                spacing: 5px;
                Text { text: "Default Browser:"; font-size: 13px; font-weight: 600; color: #bac2de; }
                ComboBox {
                    model: ["1. Zen Browser", "2. LibreWolf", "3. Firefox", "4. Brave"];
                    current-value: root.selected_browser;
                    selected(val) => { root.selected_browser = val; }
                    height: 35px;
                }
            }

            VerticalBox {
                spacing: 5px;
                Text { text: "Desktop Environment:"; font-size: 13px; font-weight: 600; color: #bac2de; }
                ComboBox {
                    model: ["1. Hyprland", "2. KDE Plasma", "3. XFCE", "4. GNOME", "5. Sway", "6. i3-wm", "7. Cinnamon", "8. Niri", "9. Qtile", "10. Wayfire", "11. bspwm", "12. Budgie", "13. Cosmic", "14. LXDE", "15. LXQt", "16. Mate", "17. Openbox"];
                    current-value: root.selected_de;
                    selected(val) => { root.selected_de = val; }
                    height: 35px;
                }
            }

            VerticalBox {
                spacing: 5px;
                Text { text: "Boot Manager:"; font-size: 13px; font-weight: 600; color: #bac2de; }
                ComboBox {
                    model: ["1. GRUB", "2. systemd-boot", "3. rEFInd", "4. Limine"];
                    current-value: root.selected_boot;
                    selected(val) => { root.selected_boot = val; }
                    height: 35px;
                }
            }
            
            CheckBox {
                text: "Apply Hyper-Performance Matrix (ZRAM, Fast I/O)";
                checked: root.perf_enabled;
                toggled => { root.perf_enabled = !root.perf_enabled; }
            }

            Text {
                text: "WARNING: Review your partitioning choice. Proceeding will write to the disk.";
                color: #f38ba8;
                font-size: 12px;
                font-weight: 700;
                horizontal-alignment: center;
                padding-top: 10px;
            }
            
            HorizontalBox {
                padding-top: 10px;
                alignment: center;
                spacing: 15px;
                Button { text: "Back"; height: 40px; clicked => { root.active_step = 2; } }
                Button {
                    text: "Begin Deployment";
                    primary: true;
                    height: 40px;
                    clicked => { 
                        root.active_step = 4; // Move to Progress Screen
                        // Send all 11 variables to Rust!
                        InstallerLogic.start_install(
                            root.selected_disk,
                            root.selected_mode,
                            root.selected_part,
                            root.in_hostname,
                            root.in_username,
                            root.in_password,
                            root.in_root_password,
                            root.selected_browser,
                            root.perf_enabled ? "Y" : "N",
                            root.selected_de,
                            root.selected_boot
                        );
                    }
                }
            }
        }

        // ==========================================
        // STEP 4: Live Progress Screen
        // ==========================================
        if (root.active_step == 4) : VerticalBox {
            alignment: center;
            spacing: 20px;
            padding-left: 50px;
            padding-right: 50px;
            
            Text {
                text: "Deploying system files...";
                font-size: 16px;
                font-weight: 600;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            
            ProgressIndicator {
                progress: InstallerLogic.progress;
                height: 20px;
            }
            
            Text {
                text: InstallerLogic.status_text;
                color: #a6adc8;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }

        // ==========================================
        // STEP 99: Complete Screen
        // ==========================================
        if (root.active_step == 99) : VerticalBox {
            alignment: center;
            spacing: 15px;
            
            Text {
                text: "Deployment Successful";
                font-size: 22px;
                font-weight: 700;
                color: #a6e3a1; 
                horizontal-alignment: center;
            }
            Text {
                text: "Kestrel OS has been installed. You may now reboot.";
                color: #bac2de;
                font-size: 14px;
                horizontal-alignment: center;
            }
        }
    }
}
