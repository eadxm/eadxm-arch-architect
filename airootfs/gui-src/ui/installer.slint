import { Button, ComboBox, ProgressIndicator, VerticalBox, HorizontalBox } from "std-widgets.slint";

export global InstallerLogic {
    // Updated to accept 3 strings: Disk, Desktop, Bootloader
    callback start_install(string, string, string);
    callback launch_terminal();
    callback update_system();
    
    in property <float> progress: 0.0;
    in property <string> status_text: "Ready to deploy.";
}

export component InstallerWindow inherits Window {
    title: "Kestrel OS Welcome";
    width: 600px;
    height: 520px; // Increased height to fit new dropdowns
    background: #1e1e2e;
    default-font-family: "sans-serif";

    in-out property <int> active_step: 0;
    property <string> selected_disk: "/dev/nvme0n1";
    property <string> selected_de: "1. Hyprland";
    property <string> selected_boot: "1. GRUB";

    VerticalBox {
        padding: 30px;
        spacing: 15px;

        Text {
            text: "Kestrel OS";
            font-size: 20px;
            font-weight: 500;
            color: #cba6f7;
            horizontal-alignment: center;
        }

        Rectangle { height: 1px; background: #313244; }

        // STEP 0: Dashboard
        if (root.active_step == 0) : VerticalBox {
            alignment: center;
            spacing: 15px;
            
            Text {
                text: "Welcome to Kestrel Arch";
                font-size: 16px;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            
            Text {
                text: "Select an option below to manage the live environment or install the system.";
                font-size: 12px;
                color: #bac2de;
                horizontal-alignment: center;
            }

            HorizontalBox {
                padding-top: 20px;
                alignment: center;
                spacing: 15px;
                
                Button {
                    text: "Launch Terminal";
                    clicked => { InstallerLogic.launch_terminal(); }
                }
                Button {
                    text: "Update System";
                    clicked => { InstallerLogic.update_system(); }
                }
                Button {
                    text: "Install Kestrel";
                    primary: true;
                    clicked => { root.active_step = 1; }
                }
            }
        }

        // STEP 1: Configuration Screen
        if (root.active_step == 1) : VerticalBox {
            alignment: center;
            spacing: 12px;
            
            // Disk Selection
            Text { text: "Target Drive"; font-size: 12px; color: #bac2de; }
            ComboBox {
                model: ["/dev/nvme0n1", "/dev/sda", "/dev/vda"];
                current-value: root.selected_disk;
                selected(val) => { root.selected_disk = val; }
            }
            
            // DE Selection
            Text { text: "Desktop Environment"; font-size: 12px; color: #bac2de; padding-top: 10px; }
            ComboBox {
                model: ["1. Hyprland", "2. KDE Plasma", "3. XFCE", "4. GNOME", "5. Sway", "6. i3-wm", "7. Cinnamon", "8. Niri", "9. Qtile", "10. Wayfire", "11. bspwm", "12. Budgie", "13. Cosmic", "14. LXDE", "15. LXQt", "16. Mate", "17. Openbox"];
                current-value: root.selected_de;
                selected(val) => { root.selected_de = val; }
            }

            // Bootloader Selection
            Text { text: "Boot Manager"; font-size: 12px; color: #bac2de; padding-top: 10px; }
            ComboBox {
                model: ["1. GRUB", "2. systemd-boot", "3. rEFInd", "4. Limine"];
                current-value: root.selected_boot;
                selected(val) => { root.selected_boot = val; }
            }

            Text {
                text: "Warning: All data on the target drive will be erased.";
                color: #f38ba8;
                font-size: 12px;
                horizontal-alignment: center;
                padding-top: 15px;
            }
            
            HorizontalBox {
                padding-top: 10px;
                alignment: center;
                spacing: 10px;
                Button {
                    text: "Back";
                    clicked => { root.active_step = 0; }
                }
                Button {
                    text: "Deploy System";
                    primary: true;
                    clicked => { 
                        root.active_step = 2; 
                        InstallerLogic.start_install(root.selected_disk, root.selected_de, root.selected_boot);
                    }
                }
            }
        }

        // STEP 2: Live Progress Output Screen
        if (root.active_step == 2) : VerticalBox {
            alignment: center;
            spacing: 12px;
            Text {
                text: "Deploying system files...";
                font-size: 14px;
                color: #cdd6f4;
                horizontal-alignment: center;
            }
            ProgressIndicator {
                progress: InstallerLogic.progress;
            }
            Text {
                text: InstallerLogic.status_text;
                color: #a6adc8;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }

        // STEP 3: Complete Screen
        if (root.active_step == 3) : VerticalBox {
            alignment: center;
            spacing: 12px;
            Text {
                text: "Installation Complete";
                font-size: 18px;
                color: #a6e3a1;
                horizontal-alignment: center;
            }
            Text {
                text: "Your system is ready to use.";
                color: #bac2de;
                font-size: 13px;
                horizontal-alignment: center;
            }
        }
    }
}
